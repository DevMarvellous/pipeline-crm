# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Required: server-side Gemini API key (used only by /api/generate-script).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: override the Gemini base URL (used by tests to point at a mock).
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com
